# Server
PORT=3001
NODE_ENV=development

# Database (MongoDB - falls back to in-memory store if unavailable)
MONGO_URI=mongodb://localhost:27017/deadman

# Redis (for BullMQ job queue - falls back gracefully if unavailable)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Optional Integrations
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=
PAGERDUTY_API_KEY=
