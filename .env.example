# DeadMan Environment Configuration

# Database
# Render should set MONGO_URI to a persistent MongoDB Atlas connection string.
# DATABASE_URL is accepted as a backwards-compatible fallback.
MONGO_URI=mongodb://localhost:27017/deadman
DATABASE_URL=

# Redis (for BullMQ background jobs)
REDIS_URL=redis://localhost:6379

# JWT & Session
JWT_SECRET=change-this-to-a-random-secret
SESSION_SECRET=change-this-to-a-random-secret

# Encryption (for storing integration secrets)
ENCRYPTION_SECRET=change-this-to-a-random-32-char-string

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google OAuth callback URL — set explicitly for production
# Falls back to BACKEND_URL/api/auth/google/callback if not set
GOOGLE_CALLBACK_URL=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth callback URL — set explicitly for production
# Falls back to BACKEND_URL/api/auth/github/callback if not set
GITHUB_CALLBACK_URL=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# PagerDuty
PAGERDUTY_API_KEY=

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Email (for password reset, email verification)
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@deadman.dev

# Backend
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
